# Copy this file to .env for local development only.
# Production must provide real environment variables through its secret manager/platform.

# Database
POSTGRES_HOST_PORT=5433
DATABASE_URL=jdbc:postgresql://localhost:5433/hotelmanagement
DATABASE_USERNAME=hotel
DATABASE_PASSWORD=hotel
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_VALIDATION_TIMEOUT_MS=5000
DB_MAX_LIFETIME_MS=1800000
DB_KEEPALIVE_TIME_MS=300000
DB_APPLICATION_NAME=hotelmanagement-backend
DB_CONNECT_RETRIES=10
DB_MIGRATION_LOCK_RETRIES=50

# Public origins and request security
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Dev uses the local Next.js proxy. In production keep false unless a listed reverse proxy is used.
TRUST_FORWARDED_HEADERS=false
TRUSTED_PROXIES=127.0.0.1,::1
AUTH_COOKIE_SECURE=false
# Lax for localhost or same-site custom domains; None requires HTTPS/secure=true.
AUTH_COOKIE_SAME_SITE=Lax

# Hotel identity and operational policy
HOTEL_NAME=Luxury Hotel
HOTEL_ADDRESS=
HOTEL_PHONE=
HOTEL_EMAIL=
HOTEL_TAX_CODE=
HOTEL_CHECK_IN_TIME=14:00
HOTEL_CHECK_OUT_TIME=12:00
HOTEL_EXTRA_HOUR_FEE=10000
HOTEL_LATE_CHECKOUT_FEE=10000
GUEST_RETENTION_DAYS=90
NO_SHOW_GRACE_MINUTES=360
DRAFT_WARNING_MINUTES=30
ARRIVAL_WINDOW_HOURS=2
REFUND_ALERT_HOURS=48

# Local demo defaults; production keeps both false except a reviewed one-time master seed.
APP_SEED_MASTER_DATA_ENABLED=true
APP_SEED_DEMO_USERS_ENABLED=true

# One-time production bootstrap only. Use a unique 12+ character mixed password,
# then disable this and remove BOOTSTRAP_ADMIN_PASSWORD after first login.
APP_BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_FULL_NAME=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PHONE=
BOOTSTRAP_ADMIN_PASSWORD=

# SendGrid: one account is reused for verification and transactional email.
VERIFICATION_SENDGRID_API_KEY=
VERIFICATION_SENDGRID_FROM_EMAIL=
VERIFICATION_SENDGRID_TEMPLATE_ID=
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_HOURS=48

# JWT keys must be different Base64 values decoding to at least 32 bytes.
JWT_EXPIRY_MINUTES=15
JWT_EXPIRY_DAY=14
JWT_ACCESS_KEY=
JWT_REFRESH_KEY=

# OAuth providers are optional. A provider is enabled only when both values are set.
# Callback URLs are derived from BACKEND_BASE_URL and FRONTEND_BASE_URL.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# Optional Gemini fallback; deterministic chatbot answers work without it.
GEMINI_API_KEY=

# VNPay legacy only: keep these while historical VNPay refunds still exist.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# Real refund/QueryDR requires a public static egress IP and explicit opt-in.
VNPAY_REFUND_IP_ADDRESS=
VNPAY_REFUND_ENABLED=false

# SePay VietQR is the active online payment channel.
# Optional QR receiving account. For BIDV/MSB/KienlongBank/OCB API Banking,
# use the active VA here while MERCHANT_BANK_ACCOUNT_NUMBER remains the
# canonical settlement account returned by SePay in webhook accountNumber.
# When omitted, MERCHANT_BANK_ACCOUNT_NUMBER below is used.
# SEPAY_QR_BANK_ACCOUNT=
# VietQR bank BIN/code/short name, for example 970436 or VCB.
# SEPAY_QR_BANK_CODE=
# SEPAY_QR_BANK_NAME=
# SEPAY_QR_ACCOUNT_HOLDER=
SEPAY_QR_TEMPLATE=compact
SEPAY_QR_BASE_URL=https://vietqr.app/img
SEPAY_STORE_NAME=Luxury Hotel
# Configure SePay to POST JSON to /api/payments/sepay/webhook. HMAC-SHA256 is
# recommended: SePay sends X-SePay-Signature and X-SePay-Timestamp.
SEPAY_WEBHOOK_SECRET=
# Alternative only: fill this when the dashboard is explicitly set to API Key.
# When set, the backend intentionally requires Authorization: Apikey <value>
# and does not fall back to HMAC after a failed API-key check.
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
SEPAY_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
SEPAY_PAYMENT_TIMEOUT_MINUTES=5
SEPAY_REFUND_WEBHOOK_TIMEOUT_MINUTES=45
# Required for reconciliation to recover transactions missed during downtime.
SEPAY_API_BASE_URL=https://userapi.sepay.vn/v2
SEPAY_API_ACCESS_TOKEN=
# Optional UUID of the linked bank account from SePay API v2.
SEPAY_API_BANK_ACCOUNT_ID=
SEPAY_RECONCILIATION_ENABLED=true
SEPAY_RECONCILIATION_INTERVAL_MS=30000
SEPAY_RECONCILIATION_LOOKBACK_HOURS=24
SEPAY_RECONCILIATION_MAX_PAGES=10

# Delay destructive/expiry maintenance while the application is starting.
MAINTENANCE_STARTUP_DELAY_MS=60000
PAYMENT_MAINTENANCE_INTERVAL_MS=300000
ROOM_HOLD_MAINTENANCE_INTERVAL_MS=120000
PRE_PAYMENT_SESSION_MINUTES=30

# Required at startup: dedicated AES-256 key, Base64 of exactly 32 random bytes.
# PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
REFUND_DATA_ENCRYPTION_KEY=
CANCELLATION_POLICY_CODE=CURRENT_CANCELLATION_POLICY
CANCELLATION_POLICY_VERSION=2026-07-19
# Optional display/audit metadata for manual bank refunds. It may mirror the
# SePay receiving account, but it never authorizes an outgoing transfer.
MERCHANT_BANK_CODE=
MERCHANT_BANK_NAME=
MERCHANT_BANK_ACCOUNT_NUMBER=
MERCHANT_BANK_ACCOUNT_NAME=

# Multipart and image validation limits
UPLOAD_MAX_FILE_SIZE=5MB
UPLOAD_MAX_REQUEST_SIZE=6MB
APP_UPLOAD_MAX_BYTES=5242880
APP_UPLOAD_MAX_WIDTH=6000
APP_UPLOAD_MAX_HEIGHT=6000
APP_UPLOAD_MAX_PIXELS=24000000
APP_UPLOAD_TEMPORARY_TTL_HOURS=24
APP_UPLOAD_ORPHAN_TTL_HOURS=24
APP_UPLOAD_CLEANUP_BATCH_SIZE=100
APP_UPLOAD_CLEANUP_CRON=0 30 3 * * *

# Select exactly one upload provider: local, cloudinary, or s3.
APP_UPLOAD_STORAGE=local
APP_UPLOAD_DIR=./storage
APP_UPLOAD_BASE_URL=http://localhost:8080/uploads
SEED_MEDIA_BASE_URL=http://localhost:8080
APP_STATIC_MEDIA_MIGRATION_ENABLED=false

# Cloudinary: required only when APP_UPLOAD_STORAGE=cloudinary or static migration is enabled.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hotel-media

# S3-compatible storage: required only when APP_UPLOAD_STORAGE=s3.
APP_UPLOAD_S3_BUCKET=
APP_UPLOAD_S3_REGION=ap-southeast-1
APP_UPLOAD_S3_ENDPOINT=
APP_UPLOAD_S3_PATH_STYLE_ACCESS=false
APP_UPLOAD_S3_KEY_PREFIX=hotel-media
APP_UPLOAD_S3_VERIFY_BUCKET=true
APP_UPLOAD_S3_SERVER_SIDE_ENCRYPTION=false

# High-risk audit email alerts and monitoring thresholds.
AUDIT_ALERT_RECIPIENTS=
AUDIT_ALERT_BATCH_SIZE=25
AUDIT_ALERT_DELIVERY_INTERVAL_MS=30000
AUDIT_ALERT_PROCESSING_TIMEOUT_MINUTES=10
MONITORING_REFUND_PENDING_THRESHOLD_MINUTES=60
MONITORING_RECONCILIATION_STALE_THRESHOLD_MINUTES=15
MONITORING_CHECKOUT_PENDING_THRESHOLD_MINUTES=30
MONITORING_ROOM_HOLD_OVERDUE_GRACE_MINUTES=5
MONITORING_EMAIL_OUTBOX_STALE_THRESHOLD_MINUTES=15
MONITORING_WEBHOOK_AUTH_FAILURE_THRESHOLD_COUNT=3
MONITORING_WEBHOOK_AUTH_FAILURE_WINDOW_MINUTES=5
