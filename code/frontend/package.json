{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const dir of ['.next','.next-dev']) fs.rmSync(dir,{recursive:true,force:true})\"",
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "next build",
    "build:clean": "pnpm run clean && pnpm run build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.65.0",
    "axios": "^1.18.0",
    "next": "^15.1.0",
    "next-intl": "^4.13.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swiper": "^14.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.14.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.2"
  }
}
