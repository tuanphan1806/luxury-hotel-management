# Next.js server-side proxy target used by /backend_proxy.
BACKEND_INTERNAL_URL=http://localhost:8080

# Canonical public origin used by metadata, robots.txt and sitemap.xml.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional error monitoring. Leave blank to disable Sentry.
NEXT_PUBLIC_SENTRY_DSN=

# Optional public hotel details used in structured data. Leave blank rather
# than publishing placeholder contact details.
HOTEL_NAME=Luxury Hotel
HOTEL_ADDRESS=
HOTEL_PHONE=
HOTEL_EMAIL=

# Public backend origin used for Google/Facebook OAuth page redirects.
# The same origin is also allow-listed by next/image for uploaded media.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Optional in local development because /backend_proxy is the default.
# For separate frontend/backend hostnames in production, set this to the same
# public backend origin as NEXT_PUBLIC_BACKEND_URL.
# NEXT_PUBLIC_API_URL=https://api.example.com
